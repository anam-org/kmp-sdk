platform :ios do
  desc "Load App Store Connect API key"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY"],
      in_house: false,
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    load_asc_api_key
    setup_ci
    match(type: "appstore", readonly: true)

    build_app(
      workspace: "apps/ios/App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      xcargs: "MARKETING_VERSION=#{ENV['APP_VERSION']} CURRENT_PROJECT_VERSION=#{ENV['BUILD_NUMBER']}",
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )
  end
end

platform :android do
  desc "Upload AAB to Google Play internal testing"
  lane :internal do
    upload_to_play_store(
      track: "internal",
      aab: "apps/android/build/outputs/bundle/release/android-release.aab",
      json_key_data: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_JSON"],
      release_status: "completed",
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
